<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registro de Horario"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bienvenido"
            android:textSize="16sp"
            android:textAlignment="center"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="32dp"/>

        <!-- Fichaje Circular Card (Mejor estética que botón cuadrado) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="240dp"
            android:layout_height="240dp"
            app:cardCornerRadius="120dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnFichar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="ENTRAR"
                android:textSize="28sp"
                android:textStyle="bold"
                android:backgroundTint="#4CAF50"
                app:cornerRadius="120dp"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pulsa el botón para registrar tu entrada o salida"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="40dp"/>

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFichajeNFC"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text=" Fichaje por NFC"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            app:iconGravity="textStart"
            android:backgroundTint="#607D8B"/>

    </LinearLayout>
</ScrollView>
